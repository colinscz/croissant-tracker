# Supabase connection — copy to `.env` and fill in with your project's values.
# Find these under Project Settings → API in the Supabase dashboard.
#
# Used by the @nuxtjs/supabase module (also read during `nuxt build/generate`).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key
